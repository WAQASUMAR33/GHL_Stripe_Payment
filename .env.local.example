# ─── GHL App Credentials ─────────────────────────────────────────────────────
# From GHL Marketplace → Your App → App Details
GHL_CLIENT_ID=your_ghl_client_id
GHL_CLIENT_SECRET=your_ghl_client_secret
GHL_PAYMENT_PROVIDER_ID=your_ghl_payment_provider_id

# The redirect URI registered in your GHL app
GHL_REDIRECT_URI=https://yourdomain.com/api/auth/ghl/callback

# GHL API base URL (v2)
GHL_API_BASE=https://services.leadconnectorhq.com

# ─── Stripe Credentials ───────────────────────────────────────────────────────
# From Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# From Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect OAuth – from Stripe Dashboard → Connect → Settings
STRIPE_CLIENT_ID=ca_...
STRIPE_CONNECT_REDIRECT_URI=https://yourdomain.com/api/auth/stripe/callback

# ─── App Config ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
APP_URL=https://yourdomain.com

# ─── MySQL Database (Prisma) ──────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev example:
DATABASE_URL="mysql://u889453186_ghl_payment:DildilPakistan786_786@195.35.59.84:3306/u889453186_ghl_payment"
